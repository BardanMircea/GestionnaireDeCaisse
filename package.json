{
  "name": "pos-epicerie",
  "version": "1.0.0",
  "description": "Logiciel de caisse sécurisé pour épicerie de quartier",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.15.3",
    "jest": "^30.4.2"
  },
  "build": {
    "appId": "com.epicerie.pos",
    "productName": "CaisseEpicerie",
    "files": [
      "src/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg"
    }
  }
}
